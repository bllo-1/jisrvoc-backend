# Copy to .env and adjust. Never commit real secrets — use a secrets manager in prod.
APP_ENV=local
DATABASE_URL=postgresql+asyncpg://jisrvoc:jisrvoc@localhost:5432/jisrvoc
REDIS_URL=redis://localhost:6379/0
USE_MOCK_DATA=true

# Auth (Jisr SSO / OIDC) — fill in for real auth; mock auth is used when blank in local
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Embedding model dimension must match db/schema.sql vector(N)
EMBEDDING_DIM=1024
