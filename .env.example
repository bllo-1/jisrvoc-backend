# Copy to .env and adjust. Never commit real secrets — use a secrets manager in prod.
APP_ENV=local
DATABASE_URL=postgresql+asyncpg://jisrvoc:jisrvoc@localhost:5432/jisrvoc
REDIS_URL=redis://localhost:6379/0
USE_MOCK_DATA=true

# Auth (Jisr SSO / OIDC) — fill in for real auth; mock auth is used when blank in local
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Embedding model dimension must match db/schema.sql vector(N)
EMBEDDING_DIM=1024

# External API Keys
# OpenAI API Key for AI classification (required for Phase 1)
OPENAI_API_KEY=

# HubSpot API Key for syncing tickets (required for Phase 1)
HUBSPOT_API_KEY=

# Zendesk credentials (optional - for Phase 1 Zendesk integration)
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Chargebee API Key for customer enrichment (required for Phase 5)
CHARGEBEE_API_KEY=
CHARGEBEE_SITE=jisr
